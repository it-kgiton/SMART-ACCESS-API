# Environment
APP_NAME=BiometricPaymentAPI
APP_VERSION=1.0.0
DEBUG=true
API_PREFIX=/api/v1

# Server
HOST=0.0.0.0
PORT=8000

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Database (Direct connection)
DATABASE_URL=postgresql+asyncpg://postgres:password@db.your-project.supabase.co:5432/postgres

# JWT
JWT_SECRET_KEY=your-jwt-secret-key-change-this
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
DEVICE_TOKEN_EXPIRE_DAYS=365

# Biometric
FACE_SIMILARITY_THRESHOLD=0.45
FINGERPRINT_MATCH_THRESHOLD=40
MAX_FACE_CANDIDATES=5
FACE_LIVENESS_ENABLED=true

# KGiTON API Integration
KGITON_API_URL=https://api.kgiton.com
KGITON_API_KEY=your-kgiton-api-key

# OTA
FIRMWARE_STORAGE_BUCKET=firmware
BIOMETRIC_STORAGE_BUCKET=biometric-assets

# CORS
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]
